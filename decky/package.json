{
  "name": "goq-sigil",
  "version": "0.1.0",
  "description": "Controller-first Decky management for a Goq Sigil appliance",
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "test:frontend": "node --test tests/model.test.mjs",
    "test:backend": "PYTHONPATH=py_modules python3 -m unittest discover -s tests/backend -v",
    "test": "pnpm run test:frontend && pnpm run test:backend"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FelineStateMachine/goq.git",
    "directory": "decky"
  },
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "1.0.2",
    "@decky/ui": "4.11.0",
    "@rollup/rollup-linux-x64-musl": "4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/react-router": "5.1.20",
    "rollup": "4.53.3",
    "typescript": "5.6.2"
  },
  "dependencies": {
    "@decky/api": "1.1.3",
    "react-icons": "5.3.0",
    "tslib": "2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
