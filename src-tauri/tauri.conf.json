{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portal",
  "version": "0.1.0",
  "identifier": "sh.goq.portal",
  "build": {
    "frontendDist": "../portal-dist",
    "beforeDevCommand": "bash ../scripts/build-portal-dist.sh",
    "beforeBuildCommand": "bash ../scripts/build-portal-dist.sh"
  },
  "app": {
    "windows": [
      {
        "title": "Portal",
        "width": 1024,
        "height": 768,
        "maximized": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["goq-invite"],
        "name": "goq Sigil invitation",
        "description": "One-time capability invitation for Portal",
        "role": "Viewer",
        "mimeType": "application/vnd.goq.invitation"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["goq"]
      }
    }
  }
}
